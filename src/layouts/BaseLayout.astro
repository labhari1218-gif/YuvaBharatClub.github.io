---
import AnnouncementBar from "../components/common/AnnouncementBar.astro";
import Footer from "../components/common/Footer.astro";
import Header from "../components/common/Header.astro";
import SeoHead from "../components/common/SeoHead.astro";
import "../styles/global.css";
import { getSiteSettings } from "../lib/content";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, image, noindex = false } = Astro.props;
const settings = await getSiteSettings();
const socials = [
  settings.instagramUrl ? { label: "Instagram", href: settings.instagramUrl } : undefined,
  settings.linkedinUrl ? { label: "LinkedIn", href: settings.linkedinUrl } : undefined,
  settings.youtubeUrl ? { label: "YouTube", href: settings.youtubeUrl } : undefined,
  settings.githubUrl ? { label: "GitHub", href: settings.githubUrl } : undefined
].filter(Boolean) as { label: string; href: string }[];
---

<!doctype html>
<html lang={settings.defaultLocale}>
  <head>
    <SeoHead title={title} description={description} image={image ?? settings.seoImage} noindex={noindex} />
  </head>
  <body>
    <AnnouncementBar announcement={settings.announcementBar} />
    <Header currentPath={Astro.url.pathname} siteTitle={settings.siteTitle} shortTitle={settings.shortTitle} />
    <main>
      <slot />
    </main>
    <Footer
      footerText={settings.footerText}
      siteTitle={settings.siteTitle}
      email={settings.email}
      socials={socials}
    />
  </body>
</html>

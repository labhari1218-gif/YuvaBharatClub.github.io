---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventCard from "../../components/events/EventCard.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import { getPublicEvents } from "../../lib/content";

const events = await getPublicEvents();
const upcoming = events.filter((event) => event.data.status === "upcoming");
const past = events.filter((event) => event.data.status !== "upcoming");
---

<BaseLayout
  title="Events | Yuva Bharat Club"
  description="Explore upcoming and past Yuva Bharat Club events, from campus discussions and competitions to student-led public activities."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Events</p>
      <h1>Events, dialogue, and campus participation</h1>
      <p class="page-hero__lead">
        This page brings together upcoming programs and selected past highlights so visitors can quickly understand
        what Yuva Bharat Club actually does on campus.
      </p>
      <p class="hero__tagline hero__tagline--hi">कार्यक्रम, संवाद और सार्थक भागीदारी।</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Upcoming"
        title="What’s coming next"
        description="Upcoming entries highlight where students can attend, participate, or volunteer. Final venue details and registration links should always be approved before publication."
      />
      {upcoming.length ? (
        <div class="card-grid">{upcoming.map((event) => <EventCard event={event} />)}</div>
      ) : (
        <EmptyState title="No upcoming events are listed yet" copy="The next approved public event will appear here once scheduling details are ready." />
      )}
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <SectionHeading
        eyebrow="Highlights"
        title="Recent public event pages"
        description="Past entries act as a clean public record. They show the club’s activity through concise summaries, approved visuals, and clear event context."
      />
      {past.length ? (
        <div class="card-grid">{past.map((event) => <EventCard event={event} />)}</div>
      ) : (
        <EmptyState title="No past event pages yet" copy="Approved event summaries and highlights will appear here as the public archive grows." />
      )}
    </div>
  </section>
</BaseLayout>

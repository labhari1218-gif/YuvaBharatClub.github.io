---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getPageEntry, getSiteSettings } from "../lib/content";
import { isPublicEmail, isPublicLink, withBase } from "../lib/site";

const page = await getPageEntry("contact-page");
const settings = await getSiteSettings();
const { Content } = await render(page);
const socials = [
  isPublicLink(settings.instagramUrl) ? { label: "Instagram", href: settings.instagramUrl } : undefined,
  isPublicLink(settings.linkedinUrl) ? { label: "LinkedIn", href: settings.linkedinUrl } : undefined,
  isPublicLink(settings.youtubeUrl) ? { label: "YouTube", href: settings.youtubeUrl } : undefined
].filter(Boolean) as { label: string; href: string }[];
const publicEmail = isPublicEmail(settings.email) ? settings.email : undefined;
---

<BaseLayout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Contact</p>
      <h1>{page.data.title}</h1>
      <p class="page-hero__lead">{page.data.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container page-grid">
      <article class="prose surface">
        <Content />
      </article>

      <aside class="sidebar-card">
        <SectionHeading title="Official public channels" description="Only approved contact details appear here." />
        <ul class="feature-list">
          {publicEmail && <li><a href={`mailto:${publicEmail}`}>{publicEmail}</a></li>}
          {socials.map((social) => (
            <li>
              <a href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
            </li>
          ))}
          {!publicEmail && !socials.length && <li>Official public contact details will appear here after approval.</li>}
          <li><a href={withBase("/join")}>See how to participate</a></li>
          <li><a href={withBase("/events")}>Browse public events</a></li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import TeamCard from "../components/ui/TeamCard.astro";
import { getPublicTeam } from "../lib/content";

const team = await getPublicTeam();
---

<BaseLayout
  title="Team | Yuva Bharat Club"
  description="Meet the public-facing team roles that organize, document, design, coordinate, and support Yuva Bharat Club."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Team</p>
      <h1>Core roles that keep the club moving</h1>
      <p class="page-hero__lead">
        This page highlights public-facing responsibilities across the club. Until final approved names are ready,
        roles are shown in a clean role-first format.
      </p>
      <p class="hero__tagline hero__tagline--hi">भूमिकाएँ स्पष्ट हों, तभी काम बेहतर चलता है।</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Core team"
        title="Operational responsibilities across the club"
        description="These entries are ordered for clarity and can later be replaced or expanded when approved public names and profiles are available."
      />
      <div class="card-grid team-grid">
        {team.map((member) => <TeamCard member={member} />)}
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryPreview from "../components/home/GalleryPreview.astro";
import Hero from "../components/home/Hero.astro";
import HighlightsGrid from "../components/home/HighlightsGrid.astro";
import JoinBanner from "../components/home/JoinBanner.astro";
import QuickValueStrip from "../components/home/QuickValueStrip.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import InitiativeCard from "../components/ui/InitiativeCard.astro";
import {
  getPublicEvents,
  getPublicGalleryAlbums,
  getPublicInitiatives,
  getSiteSettings,
  pickFeatured
} from "../lib/content";

const settings = await getSiteSettings();
const events = await getPublicEvents();
const initiatives = (await getPublicInitiatives()).slice(0, 3);
const galleryAlbums = await getPublicGalleryAlbums();
const featuredEvents = events.slice(0, 3);
const featuredAlbums = pickFeatured(galleryAlbums, settings.homepage.featuredGallerySlugs);
---

<BaseLayout title="Yuva Bharat Club" description={settings.siteDescription}>
  <Hero settings={settings} />
  <QuickValueStrip />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="About snapshot"
        title="A student-led platform for ideas, participation, and youth action"
        description="Yuva Bharat Club creates meaningful opportunities for students to participate, lead, collaborate, and contribute through events, discussions, initiatives, and community-oriented activities at IISER Bhopal."
      />
      <div class="about-snapshot surface">
        <p>
          The public site stays deliberately simple: it explains what the club is, shows event-backed proof of activity,
          and gives students a clear path to participate without exposing internal coordination or unnecessary detail.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Featured events"
        title="Recent and flagship public activity"
        description="A smaller set of event cards is enough to show the club’s work without turning the homepage into an archive."
        actionLabel="All events"
        actionHref="/events"
      />
      <HighlightsGrid events={featuredEvents} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Focus areas"
        title="Three clear ways the club shows up on campus"
        description="The homepage keeps this section tight so visitors understand the club’s core work at a glance."
      />
      <div class="card-grid">
        {initiatives.map((initiative) => <InitiativeCard initiative={initiative} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Gallery"
        title="A lighter visual preview"
        description="A small image preview is enough on the homepage. The full album structure stays on the gallery page."
      />
      <GalleryPreview albums={featuredAlbums} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <JoinBanner joinUrl={settings.joinUrl} />
    </div>
  </section>
</BaseLayout>

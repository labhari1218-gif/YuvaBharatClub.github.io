---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReportCard from "../../components/ui/ReportCard.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import { getPublicReports } from "../../lib/content";

const reports = await getPublicReports();
---

<BaseLayout
  title="Reports | Yuva Bharat Club"
  description="Read approved event summaries, public reports, and selected documentation that showcase the club’s work and learning."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Reports</p>
      <h1>Reports and summaries from public activities</h1>
      <p class="page-hero__lead">These pages capture what was organized, discussed, or learned in a concise public format.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Public documents"
        title="Summaries, notes, and approved PDF links"
        description="Some reports include PDFs, while others work as short written recaps."
      />
      <div class="card-grid">
        {reports.map((report) => <ReportCard report={report} />)}
      </div>
    </div>
  </section>
</BaseLayout>

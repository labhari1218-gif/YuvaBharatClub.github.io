---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBanner from "../components/ui/CtaBanner.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getPageEntry, getSiteSettings } from "../lib/content";

const page = await getPageEntry("join");
const settings = await getSiteSettings();
const { Content } = await render(page);
---

<BaseLayout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Join</p>
      <h1>{page.data.title}</h1>
      <p class="page-hero__lead">{page.data.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container page-grid">
      <article class="prose surface">
        <Content />
      </article>

      <aside class="sidebar-card">
        <SectionHeading title="Public pathways" description="Use approved public links only. If the form is not ready, email remains the fallback." />
        <ul class="feature-list">
          {settings.registrationLinks?.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            </li>
          ))}
          <li><a href={`mailto:${settings.email}`}>{settings.email}</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <CtaBanner
        title="Take the next public step"
        copy="The website stays privacy-safe by routing participation through approved public forms and the official club email."
        primaryLabel={settings.joinUrl ? "Open join form" : "Email the club"}
        primaryHref={settings.joinUrl ?? `mailto:${settings.email}`}
        secondaryLabel="Browse events"
        secondaryHref="/events"
      />
    </div>
  </section>
</BaseLayout>

---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBanner from "../components/ui/CtaBanner.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getPageEntry, getSiteSettings } from "../lib/content";
import { isPublicEmail, isPublicLink, withBase } from "../lib/site";

const page = await getPageEntry("join-page");
const settings = await getSiteSettings();
const { Content } = await render(page);
const publicEmail = isPublicEmail(settings.email) ? settings.email : undefined;
const publicJoinUrl = isPublicLink(settings.joinUrl) ? settings.joinUrl : undefined;
const publicRegistrationLinks = settings.registrationLinks?.filter((link) => isPublicLink(link.href)) ?? [];
---

<BaseLayout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
>
  <section class="page-hero">
    <div class="container">
      <p class="section-heading__eyebrow">Join</p>
      <h1>{page.data.title}</h1>
      <p class="page-hero__lead">{page.data.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container page-grid">
      <article class="prose surface">
        <Content />
      </article>

      <aside class="sidebar-card">
        <SectionHeading title="Public pathways" description="Only approved forms and official contact channels are shown here." />
        <ul class="feature-list">
          {publicRegistrationLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            </li>
          ))}
          {publicEmail && <li><a href={`mailto:${publicEmail}`}>{publicEmail}</a></li>}
          {!publicRegistrationLinks.length && !publicEmail && <li>Participation details are shared through approved public event and initiative pages.</li>}
          <li><a href={withBase("/events")}>Browse events</a></li>
          <li><a href={withBase("/initiatives")}>Explore initiatives</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <CtaBanner
        title="Take the next public step"
        copy="If an approved form is available, use it. Otherwise, explore the club’s public work and participate through upcoming events and initiatives."
        primaryLabel={publicJoinUrl ? "Open join form" : "Browse events"}
        primaryHref={publicJoinUrl ?? "/events"}
        secondaryLabel={publicEmail ? "Email the club" : "Explore initiatives"}
        secondaryHref={publicEmail ? `mailto:${publicEmail}` : "/initiatives"}
      />
    </div>
  </section>
</BaseLayout>

---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../lib/date";
import { assetUrl, withBase } from "../../lib/site";

interface Props {
  report: CollectionEntry<"reports">;
}

const { report } = Astro.props;
---

<article class="card">
  {report.data.coverImage && (
    <img
      class="card__media"
      src={assetUrl(report.data.coverImage)}
      alt={report.data.title}
      loading="lazy"
      width="640"
      height="420"
    />
  )}
  <div class="card__body">
    <div class="card__meta">
      <span>Report</span>
      <span>{formatDate(report.data.date)}</span>
    </div>
    <h3>{report.data.title}</h3>
    <p>{report.data.abstract}</p>
    <a class="text-link" href={withBase(`/reports/${report.slug}`)}>Read summary</a>
  </div>
</article>

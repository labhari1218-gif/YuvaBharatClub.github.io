---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../lib/date";
import { assetUrl, withBase } from "../../lib/site";

interface Props {
  album: CollectionEntry<"gallery">;
}

const { album } = Astro.props;
const albumSummary = album.data.eventRef
  ? "A curated visual snapshot connected to one of the club’s public events."
  : "A visual snapshot of preparation, participation, and club activity on campus.";
---

<article class="card">
  <img
    class="card__media"
    src={assetUrl(album.data.coverImage)}
    alt={album.data.title}
    loading="lazy"
    width="640"
    height="420"
  />
  <div class="card__body">
    <div class="card__meta">
      <span>Album</span>
      <span>{formatDate(album.data.date)}</span>
    </div>
    <h3>{album.data.title}</h3>
    <p>{albumSummary}</p>
    <a class="text-link" href={withBase(`/gallery/${album.data.slug}`)}>View album</a>
  </div>
</article>

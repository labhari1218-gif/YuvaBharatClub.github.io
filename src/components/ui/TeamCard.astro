---
import type { CollectionEntry } from "astro:content";
import { assetUrl } from "../../lib/site";

interface Props {
  member: CollectionEntry<"team">;
}

const { member } = Astro.props;
---

<article class="card team-card">
  {member.data.photo && (
    <img
      class="team-card__media"
      src={assetUrl(member.data.photo)}
      alt={member.data.name}
      loading="lazy"
      width="480"
      height="520"
    />
  )}
  <div class="card__body">
    <div class="card__meta">
      <span>{member.data.workingArea}</span>
      <span>{member.data.batch ?? "Public role"}</span>
    </div>
    <h3>{member.data.name}</h3>
    <p class="team-card__role">{member.data.role}</p>
    <p>{member.data.shortBio}</p>
    {member.data.emailOrSocial && (
      <a class="text-link" href={member.data.emailOrSocial} target="_blank" rel="noreferrer">
        Public profile
      </a>
    )}
  </div>
</article>

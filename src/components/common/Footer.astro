---
import { assetUrl, withBase } from "../../lib/site";

interface SocialLink {
  label: string;
  href: string;
}

interface Props {
  footerText: string;
  siteTitle: string;
  email?: string;
  socials: SocialLink[];
}

const { footerText, siteTitle, email, socials } = Astro.props;
const hasMeta = Boolean(email || socials.length);
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <img src={assetUrl("/logo/ybc-logo-reference.png")} alt={`${siteTitle} logo`} width="92" height="92" />
      <div>
        <h2>{siteTitle}</h2>
        <p>{footerText}</p>
      </div>
    </div>

    <div>
      <h3>Explore</h3>
      <ul class="footer-list">
        <li><a href={withBase("/about")}>About</a></li>
        <li><a href={withBase("/events")}>Events</a></li>
        <li><a href={withBase("/initiatives")}>Initiatives</a></li>
        <li><a href={withBase("/team")}>Team</a></li>
      </ul>
    </div>

    <div>
      <h3>More</h3>
      <ul class="footer-list">
        <li><a href={withBase("/gallery")}>Gallery</a></li>
        <li><a href={withBase("/reports")}>Reports</a></li>
        <li><a href={withBase("/join")}>Join</a></li>
        <li><a href={withBase("/contact")}>Contact</a></li>
      </ul>
    </div>
  </div>
  {hasMeta && (
    <div class="container site-footer__meta">
      {email && <a href={`mailto:${email}`}>{email}</a>}
      <div class="site-footer__socials">
        {
          socials.map((social) => (
            <a href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
          ))
        }
      </div>
    </div>
  )}
</footer>
